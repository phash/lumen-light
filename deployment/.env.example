# Kopiere zu .env und passe Werte an (Secrets via `openssl rand -hex 24`).
# Wird von deployment/docker-compose.prod.yml gelesen.
# Topologie: alles unter lumen.mr-development.de (SPA, /api, /auth, /lumen-images).

# --- PostgreSQL (Lumen-DB; Keycloak nutzt separate DB 'keycloak' derselben Instanz) ---
POSTGRES_USER=lumen
POSTGRES_PASSWORD=bitte-aendern-strong-password
POSTGRES_DB=lumen

# --- Keycloak (self-contained, unter /auth derselben Domain) ---
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=bitte-aendern-strong-password
# WICHTIG: relativen Pfad /auth mit angeben — sonst baut Keycloak den Issuer
# OHNE /auth (https://.../realms/lumen) und der Backend-iss-Check schlaegt fehl.
KC_HOSTNAME=https://lumen.mr-development.de/auth
# Issuer = KC_HOSTNAME + /realms/lumen — muss exakt dem Token-iss-Claim entsprechen.
KEYCLOAK_ISSUER=https://lumen.mr-development.de/auth/realms/lumen
KEYCLOAK_AUDIENCE=lumen-api
JWK_CACHE_SECONDS=600
# Optional: Service-Account fuer DELETE /me (loescht auch den KC-User). Leer = KC-Account bleibt.
KEYCLOAK_ADMIN_CLIENT_ID=
KEYCLOAK_ADMIN_CLIENT_SECRET=

# --- MinIO (S3-Storage) ---
MINIO_ROOT_USER=lumen
MINIO_ROOT_PASSWORD=bitte-aendern-strong-password
# Intern fuer head/delete (API <-> MinIO), oeffentlich fuer Pre-Signed-Browser-URLs.
GARAGE_S3_ENDPOINT=http://lumen-minio:9000
GARAGE_S3_PUBLIC_ENDPOINT=https://lumen.mr-development.de
GARAGE_S3_REGION=us-east-1
GARAGE_S3_BUCKET=lumen-images
# ACCESS_KEY/SECRET = MINIO_ROOT_USER/PASSWORD (gleiche Werte eintragen).
GARAGE_S3_ACCESS_KEY_ID=lumen
GARAGE_S3_SECRET_ACCESS_KEY=bitte-aendern-strong-password
PRESIGNED_URL_EXPIRES_IN=900
MAX_IMAGE_SIZE_BYTES=209715200

# --- CORS / Frontend-Origin ---
CORS_ORIGIN=https://lumen.mr-development.de

# --- SMTP (Keycloak Verify-Email ueber den Projektmailserver) ---
# deploy.sh setzt diese per kcadm in den lumen-Realm (kein Secret im Realm-JSON).
SMTP_HOST=mail.mr-development.de
SMTP_PORT=587
SMTP_FROM=noreply-lumen@mr-development.de
SMTP_FROM_DISPLAY=Lumen
SMTP_USER=noreply-lumen@mr-development.de
SMTP_PASSWORD=bitte-aendern-mailserver-account-passwort
