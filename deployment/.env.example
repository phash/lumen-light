# Kopiere zu .env und passe Werte an.
# Wird von deployment/docker-compose.prod.yml gelesen.

# --- PostgreSQL (Lumen-DB) ---
POSTGRES_USER=lumen
POSTGRES_PASSWORD=bitte-aendern-strong-password
POSTGRES_DB=lumen

# --- Keycloak (siehe ADR-010) ---
# Issuer-URL des Realms 'lumen' — muss exakt dem entsprechen, was im
# Token unter dem 'iss'-Claim steht.
KEYCLOAK_ISSUER=https://auth.mr-development.de/realms/lumen
KEYCLOAK_AUDIENCE=lumen-api
JWK_CACHE_SECONDS=600

# --- Garage S3 (siehe ADR-011) ---
# Endpoint ist die interne Adresse im caddy-proxy-Netz; Browser sieht das
# nie, weil Pre-Signed URLs gegen die externe URL ausgegeben werden.
GARAGE_S3_ENDPOINT=http://garage:3900
GARAGE_S3_REGION=garage
GARAGE_S3_BUCKET=lumen-images
GARAGE_S3_ACCESS_KEY_ID=<aus infra/garage/init.sh>
GARAGE_S3_SECRET_ACCESS_KEY=<aus infra/garage/init.sh>
PRESIGNED_URL_EXPIRES_IN=900
MAX_IMAGE_SIZE_BYTES=209715200

# --- CORS ---
CORS_ORIGIN=https://lumen.mr-development.de
