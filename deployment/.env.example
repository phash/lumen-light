# Kopiere zu .env und passe Werte an

# --- PostgreSQL (Lumen-DB) ---
POSTGRES_USER=lumen
POSTGRES_PASSWORD=bitte-aendern-strong-password
POSTGRES_DB=lumen

# Vollstaendige DATABASE_URL (innerhalb Docker-Compose: postgres-Service)
DATABASE_URL=postgresql+asyncpg://lumen:bitte-aendern-strong-password@postgres:5432/lumen

# --- Keycloak (siehe ADR-010) ---
# Issuer-URL des Realms 'lumen' — extern (was im Browser steht):
#   z. B. https://auth.mr-development.de/realms/lumen
# Lokal: http://localhost:18080/realms/lumen
KEYCLOAK_ISSUER=https://auth.mr-development.de/realms/lumen

# Erwartete Audience im Token (siehe Audience-Mapper im Realm-Export)
KEYCLOAK_AUDIENCE=lumen-api

# JWK-Cache TTL in Sekunden (Default 600)
JWK_CACHE_SECONDS=600

# --- Garage S3 (siehe ADR-011) — wird in Iteration 6 aktiviert ---
# GARAGE_S3_ENDPOINT=http://garage:3900
# GARAGE_S3_REGION=garage
# GARAGE_S3_BUCKET=lumen-images
# GARAGE_S3_ACCESS_KEY_ID=<aus 'garage key create'>
# GARAGE_S3_SECRET_ACCESS_KEY=<aus 'garage key create'>

# --- CORS ---
CORS_ORIGIN=https://lumen.mr-development.de
