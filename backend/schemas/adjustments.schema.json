{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lumen.example.com/schemas/adjustments.schema.json",
  "title": "Adjustments",
  "description": "Slider-Werte eines Lumen-Presets. Single Source of Truth für Frontend, Backend und Shader-Uniforms.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "exposure", "contrast", "highlights", "shadows",
    "whites", "blacks", "temperature", "tint",
    "vibrance", "saturation",
    "sharpness", "noiseReduction",
    "highlightRecovery"
  ],
  "properties": {
    "exposure":    { "type": "number", "minimum": -5, "maximum": 5, "default": 0, "description": "Belichtung in Blendenstufen" },
    "contrast":    { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
    "highlights":  { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
    "shadows":     { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
    "whites":      { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
    "blacks":      { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
    "temperature": { "type": "number", "minimum": -1, "maximum": 1, "default": 0, "description": "Weißabgleich-Verschiebung blau↔gelb" },
    "tint":        { "type": "number", "minimum": -1, "maximum": 1, "default": 0, "description": "Weißabgleich-Verschiebung grün↔magenta" },
    "vibrance":    { "type": "number", "minimum": -1, "maximum": 1, "default": 0, "description": "Sättigung mit Schutz für gesättigte Farben" },
    "saturation":  { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
    "sharpness":      { "type": "number", "minimum": 0, "maximum": 1, "default": 0, "description": "Unsharp-Mask-Staerke" },
    "noiseReduction": { "type": "number", "minimum": 0, "maximum": 1, "default": 0, "description": "Bilateral-3x3 Light" },
    "highlightRecovery": { "type": "number", "minimum": 0, "maximum": 1, "default": 0, "description": "Pull-Down geclippter Channels auf das Mittel der unclipped Channels (RawTherapee Blend-Modus)" },
    "hsl": {
      "description": "8 Farbtonbereiche × 3 Achsen. null = HSL inaktiv (spart Speicher in JSONB für Pre-E1-Presets).",
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/HslAdjustments" }
      ],
      "default": null
    },
    "toneCurve": {
      "description": "Punktbasierte Tonwertkurve (2..8 Punkte, sortiert). null = Identität.",
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/ToneCurve" }
      ],
      "default": null
    }
  },
  "$defs": {
    "HslAxis": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "red":     { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
        "orange":  { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
        "yellow":  { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
        "green":   { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
        "aqua":    { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
        "blue":    { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
        "violet":  { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
        "magenta": { "type": "number", "minimum": -1, "maximum": 1, "default": 0 }
      }
    },
    "HslAdjustments": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hue":        { "$ref": "#/$defs/HslAxis" },
        "saturation": { "$ref": "#/$defs/HslAxis" },
        "luminance":  { "$ref": "#/$defs/HslAxis" }
      }
    },
    "ToneCurvePoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number", "minimum": 0, "maximum": 1 },
        "y": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "ToneCurve": {
      "type": "object",
      "additionalProperties": false,
      "required": ["points"],
      "properties": {
        "points": {
          "type": "array",
          "minItems": 2,
          "maxItems": 8,
          "items": { "$ref": "#/$defs/ToneCurvePoint" }
        }
      }
    }
  }
}
