{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lumen.example.com/schemas/adjustments.schema.json",
  "title": "Adjustments",
  "description": "Slider-Werte eines Lumen-Presets. Single Source of Truth für Frontend, Backend und Shader-Uniforms.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "exposure", "contrast", "highlights", "shadows",
    "whites", "blacks", "temperature", "tint",
    "vibrance", "saturation"
  ],
  "properties": {
    "exposure":    { "type": "number", "minimum": -5, "maximum": 5, "default": 0, "description": "Belichtung in Blendenstufen" },
    "contrast":    { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
    "highlights":  { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
    "shadows":     { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
    "whites":      { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
    "blacks":      { "type": "number", "minimum": -1, "maximum": 1, "default": 0 },
    "temperature": { "type": "number", "minimum": -1, "maximum": 1, "default": 0, "description": "Weißabgleich-Verschiebung blau↔gelb" },
    "tint":        { "type": "number", "minimum": -1, "maximum": 1, "default": 0, "description": "Weißabgleich-Verschiebung grün↔magenta" },
    "vibrance":    { "type": "number", "minimum": -1, "maximum": 1, "default": 0, "description": "Sättigung mit Schutz für gesättigte Farben" },
    "saturation":  { "type": "number", "minimum": -1, "maximum": 1, "default": 0 }
  }
}
