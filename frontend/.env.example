# Lumen Frontend — Build-Time-Konfiguration
# Kopiere zu .env.local fuer lokale Entwicklung.
# Production: Run-Time-Config wird in Iteration 7 ueber /config.json geliefert.

# Keycloak (siehe ADR-010)
VITE_KEYCLOAK_AUTHORITY=http://localhost:18080/realms/lumen
VITE_KEYCLOAK_CLIENT_ID=lumen-frontend

# Backend-API (FastAPI)
VITE_API_BASE=http://localhost:8000/api/v1
